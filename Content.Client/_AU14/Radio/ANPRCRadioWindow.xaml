<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
               Title="{Loc anprc-window-title}"
               MinWidth="400"
               MinHeight="420"
               SetSize="420 680">

  <PanelContainer>
    <PanelContainer.PanelOverride>
      <gfx:StyleBoxFlat BackgroundColor="#0E0F13" />
    </PanelContainer.PanelOverride>

    <BoxContainer Orientation="Vertical" Margin="6" SeparationOverride="5">

      <!-- Header -->
      <PanelContainer>
        <PanelContainer.PanelOverride>
          <gfx:StyleBoxFlat BackgroundColor="#181A20" BorderColor="#343846" BorderThickness="1" />
        </PanelContainer.PanelOverride>
        <BoxContainer Orientation="Horizontal" Margin="6,4" SeparationOverride="6">
          <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="1">
            <Label Text="AN/PRC-117G" FontColorOverride="#C8D2E8" />
            <Label Text="RTO MANPACK RELAY" FontColorOverride="#687A9A" />
          </BoxContainer>
          <BoxContainer Orientation="Vertical" SeparationOverride="1">
            <Label Name="HeaderPowerLabel" Text="PWR: ---"  FontColorOverride="#687A9A" />
            <Label Name="HeaderLinkLabel"  Text="LINK: ---" FontColorOverride="#687A9A" />
          </BoxContainer>
        </BoxContainer>
      </PanelContainer>

      <ScrollContainer VerticalExpand="True" SizeFlagsStretchRatio="3">
        <BoxContainer Orientation="Vertical" SeparationOverride="5">

          <!-- LCD -->
          <PanelContainer>
            <PanelContainer.PanelOverride>
              <gfx:StyleBoxFlat BackgroundColor="#07130A" BorderColor="#245236" BorderThickness="2" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="8,6" SeparationOverride="3">
              <BoxContainer Orientation="Horizontal" SeparationOverride="5">
                <Label Name="LcdModeLabel"  Text="MODE: FH"  FontColorOverride="#4A7A55" />
                <Control HorizontalExpand="True" />
                <Label Name="TxIndicator"   Text="●"        FontColorOverride="#1E4A2E" />
                <Label Name="TxLabel"       Text="OFF"      FontColorOverride="#1E4A2E" />
                <Label Name="CryptoLabel"   Text="SEC"      FontColorOverride="#4A7A55" />
              </BoxContainer>
              <Label Name="FrequencyLabel"   Text="-- . ---"      FontColorOverride="#1E4A2E" />
              <Label Name="ChannelNameLabel" Text="NO NET LOADED" FontColorOverride="#1E4A2E" />
              <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                <Label Name="ChannelIdLabel" Text="CH: ---"   FontColorOverride="#4A7A55" HorizontalExpand="True" />
                <Label Name="BandLabel"      Text="BAND: ---" FontColorOverride="#4A7A55" />
                <Label Name="WaveformLabel"  Text="WF: ---"   FontColorOverride="#4A7A55" />
              </BoxContainer>
              <BoxContainer Orientation="Horizontal" SeparationOverride="6" Margin="0,3,0,0">
                <Label Text="SIG" FontColorOverride="#4A7A55" />
                <Label Name="SignalBarsLabel"  Text="░░░░░░░░" FontColorOverride="#1E4A2E" HorizontalExpand="True" />
                <Label Text="BAT" FontColorOverride="#4A7A55" />
                <Label Name="BatteryBarsLabel" Text="░░░░░░"   FontColorOverride="#1E4A2E" />
              </BoxContainer>
              <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                <Label Name="BitStatusLabel" Text="BIT: OFFLINE" FontColorOverride="#4A7A55" HorizontalExpand="True" />
                <Label Name="AntennaLabel"   Text="ANT: ---"     FontColorOverride="#4A7A55" HorizontalExpand="True" />
                <Label Name="FaultLabel"     Text="FAULT: NONE"  FontColorOverride="#687A9A" />
              </BoxContainer>
            </BoxContainer>
          </PanelContainer>

          <!-- Callsign -->
          <BoxContainer Orientation="Horizontal" Margin="2,1,2,0">
            <Label Text="CALLSIGN" FontColorOverride="#A9C3E8" HorizontalExpand="True" />
            <Label Name="CallsignDisplayLabel" Text="NOT SET" FontColorOverride="#687A9A" />
          </BoxContainer>
          <PanelContainer>
            <PanelContainer.PanelOverride>
              <gfx:StyleBoxFlat BackgroundColor="#17181D" BorderColor="#3D4059" BorderThickness="1" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="6,5" SeparationOverride="4">
              <BoxContainer Orientation="Horizontal" SeparationOverride="4">
                <OptionButton Name="CallsignPresetButton" MinWidth="110" />
                <LineEdit Name="CallsignLineEdit"
                          HorizontalExpand="True"
                          PlaceHolder="Max 16 chars (e.g. LIMA-6)" />
                <Button Name="CallsignSetButton" Text="SET" MinWidth="48" />
              </BoxContainer>
              <Label Text="Station override. Blank = your assigned callsign (AUTO). SET empty to clear." FontColorOverride="#4A7A55" />
              <Button Name="DirectoryButton" Text="CALLSIGN DIRECTORY" />
            </BoxContainer>
          </PanelContainer>

          <!-- Preset slots -->
          <BoxContainer Orientation="Horizontal" Margin="2,1,2,0">
            <Label Text="PRESET NETS" FontColorOverride="#A9C3E8" HorizontalExpand="True" />
            <Label Name="PresetSummaryLabel" Text="0/4" FontColorOverride="#687A9A" />
          </BoxContainer>

          <PanelContainer Name="PresetPanel">
            <PanelContainer.PanelOverride>
              <gfx:StyleBoxFlat BackgroundColor="#17181D" BorderColor="#3D4059" BorderThickness="1" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="5" SeparationOverride="4">
              <!-- Slot rows are added dynamically from code-behind -->
              <BoxContainer Name="SlotListContainer" Orientation="Vertical" SeparationOverride="3" />
              <!-- ADD button row -->
              <BoxContainer Orientation="Horizontal" SeparationOverride="4">
                <Button Name="AddSlotButton" Text="+ ADD NET" HorizontalExpand="True" />
              </BoxContainer>
              <Label Text=":r transmits on the selected net." FontColorOverride="#4A7A55" />
            </BoxContainer>
          </PanelContainer>

          <!-- Add-slot panel (hidden by default) -->
          <PanelContainer Name="AddSlotPanel">
            <PanelContainer.PanelOverride>
              <gfx:StyleBoxFlat BackgroundColor="#0E1A10" BorderColor="#245236" BorderThickness="2" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="6,5" SeparationOverride="4">
              <Label Text="NEW NET LABEL:" FontColorOverride="#A9C3E8" />
              <BoxContainer Orientation="Horizontal" SeparationOverride="4">
                <LineEdit Name="AddSlotLabelEdit"
                          HorizontalExpand="True"
                          PlaceHolder="Max 8 chars (e.g. CMD)" />
                <Button Name="AddSlotConfirmButton" Text="ADD"    MinWidth="48" />
                <Button Name="AddSlotCancelButton"  Text="CANCEL" MinWidth="60" />
              </BoxContainer>
            </BoxContainer>
          </PanelContainer>

          <!-- Slot entry panel (hidden by default) -->
          <PanelContainer Name="SlotEntryPanel">
            <PanelContainer.PanelOverride>
              <gfx:StyleBoxFlat BackgroundColor="#0E1A10" BorderColor="#245236" BorderThickness="2" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="6,5" SeparationOverride="4">
              <Label Name="SlotEntryHeaderLabel" Text="TUNE SLOT:" FontColorOverride="#A9C3E8" />

              <!-- Tab buttons -->
              <BoxContainer Orientation="Horizontal" SeparationOverride="4">
                <Button Name="EntryTabFreqButton" Text="FREQ"  HorizontalExpand="True" />
                <Button Name="EntryTabNetButton"  Text="NET"   HorizontalExpand="True" />
                <Button Name="EntryTabClearButton" Text="CLEAR" HorizontalExpand="True" />
              </BoxContainer>

              <!-- FREQ tab content -->
              <BoxContainer Name="EntryFreqPanel" Orientation="Horizontal" SeparationOverride="4">
                <LineEdit Name="EntryFreqLineEdit"
                          HorizontalExpand="True"
                          PlaceHolder="e.g. 1606 or 1.606" />
                <Button Name="EntryFreqConfirmButton" Text="SET"    MinWidth="48" />
              </BoxContainer>

              <!-- NET tab content: scrollable channel list -->
              <ScrollContainer Name="EntryNetScroll" MinHeight="120" MaxHeight="160">
                <BoxContainer Name="EntryNetList" Orientation="Vertical" SeparationOverride="2" />
              </ScrollContainer>

              <Button Name="SlotEntryCloseButton" Text="CLOSE" />
            </BoxContainer>
          </PanelContainer>

          <!-- Controls -->
          <PanelContainer>
            <PanelContainer.PanelOverride>
              <gfx:StyleBoxFlat BackgroundColor="#17181D" BorderColor="#3D4059" BorderThickness="1" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="6,5" SeparationOverride="4">
              <BoxContainer Orientation="Horizontal" SeparationOverride="4">
                <Button Name="ModeButton"    HorizontalExpand="True" Text="MODE FH"  />
                <Button Name="MonitorButton" HorizontalExpand="True" Text="MON OFF"  />
                <Button Name="ScanButton"    HorizontalExpand="True" Text="SCAN OFF" />
                <Button Name="SquelchButton" HorizontalExpand="True" Text="SQL 3"    />
                <Button Name="TxPowerButton" HorizontalExpand="True" Text="TX MED"   />
              </BoxContainer>
              <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                <Label Text="ROLE"  FontColorOverride="#687A9A" />
                <Label Name="RoleValueLabel"  Text="RTO RELAY" FontColorOverride="#C8D2E8" HorizontalExpand="True" />
                <Label Text="RELAY" FontColorOverride="#687A9A" />
                <Label Name="RelayValueLabel" Text="STBY"      FontColorOverride="#C8D2E8" />
              </BoxContainer>
              <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                <Label Name="DiagnosticLineA" Text="ANCHOR: OFFLINE" FontColorOverride="#687A9A" HorizontalExpand="True" />
                <Label Name="DiagnosticLineB" Text="BYPASS: NO"      FontColorOverride="#687A9A" />
              </BoxContainer>
              <BoxContainer Orientation="Horizontal" SeparationOverride="4" Margin="0,3,0,0">
                <Button Name="RadioCheckButton" Text="RADIO CHECK" HorizontalExpand="True" />
              </BoxContainer>
            </BoxContainer>
          </PanelContainer>

          <!-- COMSEC -->
          <BoxContainer Orientation="Horizontal" Margin="2,1,2,0">
            <Label Text="COMSEC" FontColorOverride="#A9C3E8" HorizontalExpand="True" />
            <Label Name="CryptoStatusLabel" Text="UNSECURED" FontColorOverride="#D65A5A" />
          </BoxContainer>
          <PanelContainer>
            <PanelContainer.PanelOverride>
              <gfx:StyleBoxFlat BackgroundColor="#17181D" BorderColor="#3D4059" BorderThickness="1" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="6,5" SeparationOverride="4">
              <Label Name="CryptoFillLabel" Text="FILL: NONE - insert fill card to load" FontColorOverride="#687A9A" />
              <BoxContainer Orientation="Horizontal" SeparationOverride="4">
                <Button Name="ZeroizeButton"  Text="ZEROIZE" HorizontalExpand="True" StyleClasses="Caution" />
                <Button Name="DestroyButton"  Text="DESTROY" HorizontalExpand="True" StyleClasses="Caution" />
              </BoxContainer>
              <Button Name="RecryptoButton" Text="{Loc anprc-recrypto-button}" StyleClasses="Caution" />
            </BoxContainer>
          </PanelContainer>

        </BoxContainer>
      </ScrollContainer>

      <!-- Net log: outside the settings scroll so it grows with the window -->
      <BoxContainer Orientation="Horizontal" Margin="2,1,2,0">
        <Label Text="NET LOG" FontColorOverride="#A9C3E8" HorizontalExpand="True" />
        <Label Name="NetLogCountLabel" Text="0 entries" FontColorOverride="#687A9A" />
      </BoxContainer>
      <BoxContainer Orientation="Horizontal" SeparationOverride="4">
        <OptionButton Name="NetLogChannelFilter" MinWidth="120" />
        <LineEdit Name="NetLogSearchEdit"
                  HorizontalExpand="True"
                  PlaceHolder="Filter sender / text" />
        <Button Name="NetLogFilterClearButton" Text="CLR" MinWidth="44" />
      </BoxContainer>
      <PanelContainer VerticalExpand="True" SizeFlagsStretchRatio="2">
        <PanelContainer.PanelOverride>
          <gfx:StyleBoxFlat BackgroundColor="#07130A" BorderColor="#245236" BorderThickness="1" />
        </PanelContainer.PanelOverride>
        <ScrollContainer VerticalExpand="True" MinHeight="100">
          <BoxContainer Name="NetLogContainer" Orientation="Vertical" SeparationOverride="2" Margin="4,3" />
        </ScrollContainer>
      </PanelContainer>

      <!-- Footer -->
      <PanelContainer>
        <PanelContainer.PanelOverride>
          <gfx:StyleBoxFlat BackgroundColor="#181A20" BorderColor="#343846" BorderThickness="1" />
        </PanelContainer.PanelOverride>
        <BoxContainer Orientation="Horizontal" Margin="6,5" SeparationOverride="6">
          <Button Name="PowerButton" Text="{Loc anprc-power-off-button}" MinWidth="96" />
          <Label Name="StatusLabel" Text="" FontColorOverride="#A9C3E8" VerticalAlignment="Center" HorizontalExpand="True" />
        </BoxContainer>
      </PanelContainer>

    </BoxContainer>
  </PanelContainer>

</DefaultWindow>
