au14-smelting-pot-wrong-material = The crucible can't render that down.
au14-smelting-pot-busy-with = The crucible is already loaded with { $material }.
au14-smelting-pot-full = The crucible is full.
au14-smelting-pot-inserted = You tip { $count } { $material } into the crucible.
au14-smelting-pot-collected = You fish { $count } { $material } out of the crucible.
au14-smelting-pot-emptied = You tip { $count } unsmelted { $material } back out.
au14-smelting-pot-emptied-scrap = You scrape the half-melted scrap out and discard it.
au14-smelting-pot-material-electronics = scrap electronics
au14-smelting-pot-nothing-ready = Nothing in the crucible is ready yet.
au14-smelting-pot-fire-occupied = There's already a crucible on that fire.
au14-smelting-pot-attached = You sit the crucible on the fire.
au14-smelting-pot-detached = You lift the crucible off the fire.

au14-smelting-pot-verb-detach = Take off fire
au14-smelting-pot-verb-empty = Tip out unsmelted material

au14-smelting-pot-examine-empty = It's empty.
au14-smelting-pot-examine-contents = It holds [color=orange]{ $count }/{ $max }[/color] { $material }.
au14-smelting-pot-examine-output = [color=lightgreen]{ $count } { $material }[/color] sit finished at the bottom, ready to collect.
au14-smelting-pot-examine-progress = The current batch looks about [color=orange]{ $percent }%[/color] rendered down.
au14-smelting-pot-examine-not-on-fire = It's stone cold. It needs to sit on a lit fire.
au14-smelting-pot-examine-fire-out = The fire beneath it has gone out.
